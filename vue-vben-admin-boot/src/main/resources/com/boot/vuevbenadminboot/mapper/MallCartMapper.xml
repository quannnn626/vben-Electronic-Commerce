<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.boot.vuevbenadminboot.mapper.MallCartMapper">

    <resultMap id="BaseResultMap" type="com.boot.vuevbenadminboot.domain.MallCart">
        <id property="id" column="id"/>
        <result property="userId" column="user_id"/>
        <result property="productId" column="product_id"/>
        <result property="skuId" column="sku_id"/>
        <result property="quantity" column="quantity"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
    </resultMap>

    <sql id="Base_Column_List">
        id
        ,user_id,product_id,sku_id,quantity,create_time,
        update_time
    </sql>

    <select id="listCartByUserId" resultType="com.boot.vuevbenadminboot.web.dto.resp.CartItemDto">
        SELECT c.id         AS cartId,
               c.product_id AS productId,
               p.name       AS productName,
               s.id         AS skuId,
               s.price      AS salePrice,
               s.stock      AS stock,
               c.quantity   AS quantity
        FROM mall_cart c
                 LEFT JOIN mall_product p
                           ON c.product_id = p.id
                 LEFT JOIN mall_sku s
                           ON c.sku_id = s.id
        WHERE c.user_id = #{userId}
        ORDER BY c.create_time DESC
    </select>
</mapper>
